# BookRecommend 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ── LLM API 配置 ──
# API Key（支持 OpenAI 及兼容接口，如 SiliconFlow、DeepSeek 等）
API_KEY=sk-your-api-key-here

# API Base URL（可选，默认 SiliconFlow）
# SiliconFlow:  https://api.siliconflow.cn/v1
# DeepSeek:     https://api.deepseek.com/v1
# OpenAI:       https://api.openai.com/v1
# 其他兼容接口填对应的 base URL
API_BASE_URL=https://api.siliconflow.cn/v1

# 模型名称
# SiliconFlow:  Qwen/Qwen3-235B-A22B, deepseek-ai/DeepSeek-V3 等
# DeepSeek:     deepseek-chat
# OpenAI:       gpt-4o, gpt-4o-mini
MODEL=deepseek-ai/DeepSeek-V3

# ── 服务配置 ──
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── ChromaDB 持久化目录 ──
CHROMA_PERSIST_DIR=./src/data/chroma

# ── 兼容旧版配置（也可用上面的新配置） ──
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
